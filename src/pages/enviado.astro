---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---
<Layout>
  <Navbar />
  <main class="min-h-screen flex items-center justify-center py-32" style="background-color:#f5f5f5">
    <div class="text-center max-w-md mx-auto px-6">
      <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-6" style="background-color:#e6f4ec">
        <svg class="w-8 h-8" style="color:#127139" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h1 class="text-3xl font-bold text-gray-900 mb-3">¡Mensaje enviado!</h1>
      <p class="text-gray-500 mb-8">Gracias por contactarnos. Te respondemos el mismo día.</p>
      <a href="/" class="inline-block px-8 py-3 rounded-xl font-semibold text-white text-sm transition-all hover:opacity-90" style="background-color:#127139">
        Volver al inicio
      </a>
    </div>
  </main>
  <Footer />
</Layout>
