---
const wa  = 'https://wa.me/523314281747?text=Hola%2C%20me%20gustar%C3%ADa%20contactarlos.';
const email = 'jaaprecolectora@gmail.com';
---
<section id="contacto" class="py-24 md:py-32" style="background-color:#f5f5f5">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <div class="text-center max-w-xl mx-auto mb-14">
      <p class="reveal text-xs font-semibold tracking-widest uppercase mb-3" style="color:#127139">Contacto</p>
      <h2 class="reveal text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 leading-tight" style="transition-delay:.08s">Hablemos.</h2>
      <p class="reveal text-base text-gray-400 mt-4" style="transition-delay:.14s">Sin compromisos. Te respondemos el mismo día.</p>
    </div>

    <div class="grid md:grid-cols-2 gap-10 lg:gap-14">

      <!-- Formulario -->
      <div class="reveal bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
        <form name="contacto" method="POST" data-netlify="true" netlify-honeypot="bot-field" onsubmit="handleSubmit(event)" class="space-y-5">
          <input type="hidden" name="form-name" value="contacto" />
          <p class="hidden"><input name="bot-field" /></p>
          <div>
            <label for="nombre" class="block text-sm font-semibold text-gray-700 mb-1.5">Nombre</label>
            <input type="text" id="nombre" name="nombre" required placeholder="Tu nombre completo"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm bg-white outline-none transition-all"
              onfocus="this.style.borderColor='#127139'" onblur="this.style.borderColor=''"/>
          </div>
          <div>
            <label for="empresa" class="block text-sm font-semibold text-gray-700 mb-1.5">Empresa</label>
            <input type="text" id="empresa" name="empresa" placeholder="Nombre de tu empresa"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm bg-white outline-none transition-all"
              onfocus="this.style.borderColor='#127139'" onblur="this.style.borderColor=''"/>
          </div>
          <div>
            <label for="mensaje" class="block text-sm font-semibold text-gray-700 mb-1.5">Mensaje</label>
            <textarea id="mensaje" name="mensaje" required rows="5" placeholder="Cuéntanos sobre tus residuos..."
              class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm bg-white outline-none transition-all resize-none"
              onfocus="this.style.borderColor='#127139'" onblur="this.style.borderColor=''"></textarea>
          </div>
          <button type="submit"
            class="w-full py-3.5 rounded-xl font-semibold text-white text-sm transition-all hover:opacity-90"
            style="background-color:#127139">Enviar mensaje</button>
          <p id="form-ok" class="hidden text-center text-sm font-semibold py-2.5 rounded-lg" style="background:#e6f4ec; color:#127139">
            ¡Mensaje enviado! Te contactamos pronto.
          </p>
        </form>
      </div>

      <!-- Datos de contacto -->
      <div class="reveal space-y-4" style="transition-delay:.12s">

        <!-- WhatsApp amarillo -->
        <a href={wa} target="_blank" rel="noopener noreferrer"
          class="flex items-center gap-5 p-7 rounded-2xl transition-all hover:scale-[1.02] hover:shadow-lg"
          style="background-color:#ffca05">
          <svg class="w-10 h-10 flex-shrink-0" style="color:#127139" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <div>
            <p class="font-bold text-xl leading-none mb-1" style="color:#127139">WhatsApp</p>
            <p class="font-semibold text-base" style="color:#127139">+52 33 1428 1747</p>
            <p class="text-xs mt-1.5" style="color:rgba(18,113,57,0.6)">Respuesta inmediata en horario de oficina</p>
          </div>
        </a>

        <!-- Correo -->
        <a href={`mailto:${email}`}
          class="flex items-center gap-4 p-6 rounded-2xl bg-white border border-gray-100 hover:shadow-md transition-all">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color:#e6f4ec">
            <svg class="w-5 h-5" style="color:#127139" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-0.5">Correo</p>
            <p class="font-semibold text-sm text-gray-800 break-all">{email}</p>
          </div>
        </a>

        <!-- Cobertura -->
        <div class="flex items-center gap-4 p-6 rounded-2xl bg-white border border-gray-100">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color:#e6f4ec">
            <svg class="w-5 h-5" style="color:#127139" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-0.5">Cobertura</p>
            <p class="font-semibold text-sm text-gray-800">Zona Metropolitana de Guadalajara</p>
            <p class="text-xs text-gray-400 mt-0.5">Guadalajara, Zapopan, Tlaquepaque, Tonalá y más</p>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>

<script>
  function handleSubmit(e: Event) {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const ok = document.getElementById('form-ok');
    const fields = form.querySelectorAll('input,textarea,button');
    fields.forEach(el => ((el as HTMLInputElement).disabled = true));

    fetch('/', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams(new FormData(form) as any).toString(),
    })
      .then(() => {
        ok?.classList.remove('hidden');
        setTimeout(() => {
          form.reset();
          fields.forEach(el => ((el as HTMLInputElement).disabled = false));
          ok?.classList.add('hidden');
        }, 4000);
      })
      .catch(() => {
        fields.forEach(el => ((el as HTMLInputElement).disabled = false));
      });
  }
  (window as any).handleSubmit = handleSubmit;
</script>
