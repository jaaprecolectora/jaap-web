---
const testimoniales = [
  {
    nombre: 'Carlos Mendoza',
    cargo: 'Gerente de Operaciones',
    empresa: 'Walmart',
    texto: 'Llevamos años trabajando con JAAP y la trazabilidad de sus reportes nos ha facilitado mucho el cumplimiento normativo.',
    inicial: 'CM',
    acento: '#127139',
  },
  {
    nombre: 'Ana Lucía Herrera',
    cargo: 'Coordinadora Ambiental',
    empresa: 'Bachoco',
    texto: 'Siempre puntuales, siempre con la documentación en orden. Un proveedor confiable.',
    inicial: 'AH',
    acento: '#ffca05',
  },
  {
    nombre: 'Roberto Zárate',
    cargo: 'Jefe de Mantenimiento',
    empresa: 'Omnilife',
    texto: 'El servicio es rápido y el trato muy profesional. Lo recomiendo sin dudarlo.',
    inicial: 'RZ',
    acento: '#127139',
  },
  {
    nombre: 'Patricia Solís',
    cargo: 'Administradora',
    empresa: 'Plaza Patria',
    texto: 'Nos resolvieron el manejo de residuos especiales sin complicaciones. Excelente equipo.',
    inicial: 'PS',
    acento: '#ffca05',
  },
  {
    nombre: 'Ing. Jorge Villanueva',
    cargo: 'Supervisor HSE',
    empresa: 'Smurfit Westrock',
    texto: 'Cumplen con todos los permisos SEMARNAT y SEMADET. Eso nos da mucha tranquilidad.',
    inicial: 'JV',
    acento: '#127139',
  },
  {
    nombre: 'Daniela Ramos',
    cargo: 'Gerente de Facility',
    empresa: 'Grupo Aeroportuario',
    texto: 'Profesionales, responsables y muy atentos. El mejor proveedor de residuos que hemos tenido.',
    inicial: 'DR',
    acento: '#ffca05',
  },
];

// Repartimos en 3 columnas y duplicamos para el loop
const col1 = [testimoniales[0], testimoniales[3]];
const col2 = [testimoniales[1], testimoniales[4]];
const col3 = [testimoniales[2], testimoniales[5]];
---

<section id="testimoniales" class="py-24 md:py-32 overflow-hidden" style="background-color:#f5f5f5">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <div class="text-center max-w-xl mx-auto mb-16">
      <p class="reveal text-xs font-semibold tracking-widest uppercase mb-3" style="color:#127139">Testimoniales</p>
      <h2 class="reveal text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 leading-tight" style="transition-delay:.08s">
        Lo que dicen nuestros clientes.
      </h2>
    </div>

    <!-- Columnas animadas -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 max-h-[560px] overflow-hidden" style="mask-image:linear-gradient(to bottom, transparent 0%, black 8%, black 92%, transparent 100%); -webkit-mask-image:linear-gradient(to bottom, transparent 0%, black 8%, black 92%, transparent 100%)">

      {[col1, col2, col3].map((col, ci) => (
        <div
          class={`flex flex-col gap-5 testi-col`}
          style={`animation: scrollUp ${14 + ci * 3}s linear infinite; animation-delay: ${ci * -4}s`}
        >
          {/* Doble para loop seamless */}
          {[...col, ...col].map((t) => (
            <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm flex-shrink-0">
              <!-- Estrellas -->
              <div class="flex gap-0.5 mb-4">
                {[1,2,3,4,5].map(() => (
                  <svg class="w-4 h-4" style="color:#ffca05" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                ))}
              </div>
              <!-- Texto -->
              <p class="text-sm text-gray-600 leading-relaxed mb-5 italic">"{t.texto}"</p>
              <!-- Autor -->
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 text-xs font-bold"
                  style={`background-color:${t.acento}; color:${t.acento === '#ffca05' ? '#127139' : 'white'}`}>
                  {t.inicial}
                </div>
                <div>
                  <p class="font-semibold text-sm text-gray-900 leading-none mb-0.5">{t.nombre}</p>
                  <p class="text-xs text-gray-400">{t.cargo}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      ))}

    </div>
  </div>
</section>

<style>
  @keyframes scrollUp {
    0%   { transform: translateY(0); }
    100% { transform: translateY(-50%); }
  }
  .testi-col:hover {
    animation-play-state: paused;
  }
</style>
