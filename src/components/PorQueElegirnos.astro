---
const razones = [
  {
    titulo: 'Servicio personalizado y específico',
    desc: 'Diseñamos un plan de manejo a la medida de tus residuos — no una solución genérica.',
    icono: `<path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>`,
  },
  {
    titulo: 'Autorización ante SEMADET y SEMARNAT',
    desc: 'Operamos con todos los permisos vigentes. Sin riesgos legales ni ambientales para tu empresa.',
    icono: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`,
  },
  {
    titulo: 'Certificado con validez ante el SAT',
    desc: 'Emitimos certificados de destrucción y disposición final con plena validez fiscal.',
    icono: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>`,
  },
  {
    titulo: '30 años de experiencia en la ZMG',
    desc: 'Tres décadas de trayectoria en Guadalajara. Conocemos el sector como nadie.',
    icono: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  },
];
---

<section id="por-que-elegirnos" class="py-24 md:py-32" style="background-color:#127139">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <div class="text-center max-w-2xl mx-auto mb-16">
      <p class="reveal text-xs font-semibold tracking-widest uppercase mb-3" style="color:rgba(255,202,5,0.7)">Nuestras ventajas</p>
      <h2 class="reveal text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight" style="transition-delay:.08s">
        Por qué elegirnos.
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {razones.map((r, i) => (
        <div class="reveal rounded-2xl p-7 transition-all hover:scale-[1.02]"
          style={`background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.13); transition-delay:${i*0.08}s`}>
          <div class="w-12 h-12 rounded-full flex items-center justify-center mb-5" style="background-color:rgba(255,202,5,0.15)">
            <svg class="w-6 h-6" style="color:#ffca05" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" set:html={r.icono} />
          </div>
          <h3 class="font-semibold text-white text-base mb-2 leading-snug">{r.titulo}</h3>
          <p class="text-sm leading-relaxed" style="color:rgba(255,255,255,0.55)">{r.desc}</p>
        </div>
      ))}
    </div>

  </div>
</section>
