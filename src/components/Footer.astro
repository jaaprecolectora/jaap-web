---
const email = 'jaaprecolectora@gmail.com';
---
<footer style="background-color:#127139">
  <div class="max-w-7xl mx-auto px-6 lg:px-10 pt-16 pb-8">

    <div class="grid md:grid-cols-3 gap-10 pb-12 border-b border-white/15">

      <!-- Logo + slogan -->
      <div>
        <img src="/JAAPFinal_blanco.svg" alt="JAAP Recolectora" class="h-9 w-auto mb-4" />
        <p class="text-sm italic mb-5" style="color:rgba(255,255,255,0.5)">"Mano dura contra la basura."</p>
        <!-- Redes sociales -->
        <div class="flex gap-3">
          <a href="https://facebook.com/jaaprecolectora" target="_blank" rel="noopener noreferrer" aria-label="Facebook"
            class="w-9 h-9 rounded-full flex items-center justify-center transition-colors hover:bg-white/20"
            style="background-color:rgba(255,255,255,0.1)">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="https://instagram.com/jaaprecolectora" target="_blank" rel="noopener noreferrer" aria-label="Instagram"
            class="w-9 h-9 rounded-full flex items-center justify-center transition-colors hover:bg-white/20"
            style="background-color:rgba(255,255,255,0.1)">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Navegación -->
      <div class="md:flex md:justify-center">
        <div>
          <p class="text-xs font-bold tracking-widest uppercase mb-5" style="color:rgba(255,255,255,0.3)">Navegación</p>
          <ul class="space-y-3">
            {[['Nosotros','#nosotros'],['Servicios','#servicios'],['Por qué elegirnos','#por-que-elegirnos'],['Clientes','#clientes'],['Contacto','#contacto']].map(([l,h]) => (
              <li>
                <a href={h} class="text-sm transition-colors" style="color:rgba(255,255,255,0.55)"
                  onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,0.55)'">
                  {l}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Contacto -->
      <div>
        <p class="text-xs font-bold tracking-widest uppercase mb-5" style="color:rgba(255,255,255,0.3)">Contacto</p>
        <ul class="space-y-3">
          <li>
            <a href="https://wa.me/523314281747" target="_blank" rel="noopener noreferrer"
              class="text-sm transition-colors" style="color:rgba(255,255,255,0.6)"
              onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">
              +52 33 1428 1747
            </a>
          </li>
          <li>
            <a href="tel:+523332294070"
              class="text-sm transition-colors" style="color:rgba(255,255,255,0.6)"
              onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">
              +52 33 32 29 4070
            </a>
          </li>
          <li>
            <a href={`mailto:${email}`}
              class="text-sm break-all transition-colors" style="color:rgba(255,255,255,0.6)"
              onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">
              {email}
            </a>
          </li>
          <li class="text-sm" style="color:rgba(255,255,255,0.5)">
            Tlajomulco de Zúñiga, Jalisco
          </li>
        </ul>
      </div>

    </div>

    <!-- Pie -->
    <div class="pt-7 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex gap-3">
        <span class="text-xs font-semibold px-2.5 py-1 rounded-full border" style="color:rgba(255,255,255,0.5); border-color:rgba(255,255,255,0.2)">Autorización SEMADET</span>
      </div>
      <p class="text-xs" style="color:rgba(255,255,255,0.3)">© 2026 JAAP Recolectora. Todos los derechos reservados.</p>
    </div>

  </div>
</footer>
