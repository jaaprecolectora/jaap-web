---
const waCotiz    = 'https://wa.me/523314281747?text=Hola%2C%20quisiera%20una%20cotizaci%C3%B3n%20sin%20costo.';
const waServicios = '#servicios';
---

<section id="inicio" class="relative min-h-screen flex flex-col justify-center pt-[68px] overflow-hidden">

  <!-- Foto de fondo -->
  <img
    src="/fotos/c632e410-6762-42e7-9951-e938b1590496.JPG"
    alt="JAAP Recolectora en operación"
    class="absolute inset-0 w-full h-full object-cover object-center"
  />

  <!-- Overlay verde oscuro -->
  <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(10,50,25,0.88) 0%, rgba(18,113,57,0.75) 100%)"></div>

  <!-- Contenido centrado -->
  <div class="relative max-w-7xl mx-auto px-6 lg:px-10 py-24 md:py-32 w-full">
    <div class="max-w-3xl">

      <span class="reveal inline-block text-xs font-semibold tracking-widest uppercase px-3 py-1.5 rounded-full border mb-8 whitespace-nowrap"
        style="color:rgba(255,202,5,0.85); border-color:rgba(255,202,5,0.25)">
        Guadalajara · Desde 1994
      </span>

      <h1 class="reveal text-5xl md:text-6xl lg:text-[5rem] font-bold leading-[1.04] tracking-tight mb-6" style="transition-delay:.07s">
        <span class="block text-white">Residuos</span>
        <span class="block" style="color:#ffca05">bajo control.</span>
      </h1>

      <p class="reveal text-base md:text-xl leading-relaxed mb-10 max-w-lg" style="color:rgba(255,255,255,0.7); transition-delay:.14s">
        Somos una empresa familiar 100% mexicana dedicada al manejo integral de residuos.
        Servicio personalizado, certificado y comprometido con el medio ambiente.
      </p>

      <div class="reveal flex flex-col sm:flex-row gap-3" style="transition-delay:.2s">
        <a href={waCotiz} target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-7 py-4 rounded-full font-semibold text-sm transition-all hover:scale-[1.03] hover:shadow-lg"
          style="background-color:#ffca05; color:#127139">
          Solicita cotización gratis
        </a>
        <a href={waServicios}
          class="inline-flex items-center justify-center px-7 py-4 rounded-full font-semibold text-sm border-2 text-white transition-all hover:bg-white/10"
          style="border-color:rgba(255,255,255,0.4)">
          Conoce nuestros servicios
        </a>
      </div>

    </div>
  </div>


</section>
