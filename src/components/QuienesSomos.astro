---
const fotos = [
  { src: '/fotos/IMG_4034.jpg',                              alt: 'Equipo JAAP Recolectora' },
  { src: '/fotos/c632e410-6762-42e7-9951-e938b1590496.JPG', alt: 'Camión JAAP en operación' },
  { src: '/fotos/IMG_6554.JPG',                              alt: 'Fabricación de contenedores' },
  { src: '/fotos/7ad560c5-f7de-4291-9daf-bda63b536beb.JPG', alt: 'Camión JAAP con logo' },
  { src: '/fotos/IMG_3623.JPG',                              alt: 'Trabajadores en operación' },
  { src: '/fotos/IMG_5250.JPG',                              alt: 'Camión JAAP lateral' },
  { src: '/fotos/IMG_2844.JPG',                              alt: 'Servicio en Omnilife' },
  { src: '/fotos/IMG_4857.JPG',                              alt: 'Operación en planta' },
  { src: '/fotos/24E529AB-CA2B-475B-BFFB-A1C34471A88C.JPG', alt: 'Operación con montacargas' },
  { src: '/fotos/9EB2AA27-8DBE-46BB-A720-C5FC7FDF4ED3.JPG', alt: 'Maquinaria industrial' },
  { src: '/fotos/A4E6A21C-D61B-4287-9D0D-BCE58CD94F0F.JPG', alt: 'Equipo de trabajo' },
  { src: '/fotos/IMG_0568.jpg',                              alt: 'Clasificación de materiales' },
  { src: '/fotos/IMG_1498.jpg',                              alt: 'Residuos en sitio' },
  { src: '/fotos/IMG_1566.jpg',                              alt: 'Plástico triturado recuperable' },
  { src: '/fotos/IMG_1567.jpg',                              alt: 'Metal triturado recuperable' },
];

const cards = [
  {
    icono: `<path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
    titulo: 'Misión',
    desc: 'Brindar soluciones integrales en el manejo de residuos con cumplimiento normativo y compromiso ambiental genuino.',
  },
  {
    icono: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>`,
    titulo: 'Visión',
    desc: 'Ser la empresa referente en manejo de residuos en el occidente de México, reconocida por calidad y trazabilidad.',
  },
  {
    icono: `<path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>`,
    titulo: 'Valores',
    desc: 'Responsabilidad, honestidad, compromiso y cuidado ambiental en cada servicio que prestamos.',
  },
];
---

<section id="nosotros" class="py-24 md:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid md:grid-cols-2 gap-14 lg:gap-20 items-stretch">

      <!-- Carrusel con TODAS las fotos -->
      <div class="reveal h-full">
        <div class="relative rounded-2xl overflow-hidden bg-gray-100 shadow-lg h-full min-h-[480px]" id="qs-carousel">
          {fotos.map((f, i) => (
            <div id={`qs-slide-${i}`}
              class={`slide absolute inset-0 ${i === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0'}`}>
              <img src={f.src} alt={f.alt} class="w-full h-full object-cover" loading={i === 0 ? 'eager' : 'lazy'} />
            </div>
          ))}

          <!-- Prev / Next -->
          <button id="qs-prev" aria-label="Anterior"
            class="absolute left-3 top-1/2 -translate-y-1/2 z-20 w-9 h-9 rounded-full bg-white/80 backdrop-blur-sm flex items-center justify-center shadow hover:bg-white transition-colors">
            <svg class="w-4 h-4 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
            </svg>
          </button>
          <button id="qs-next" aria-label="Siguiente"
            class="absolute right-3 top-1/2 -translate-y-1/2 z-20 w-9 h-9 rounded-full bg-white/80 backdrop-blur-sm flex items-center justify-center shadow hover:bg-white transition-colors">
            <svg class="w-4 h-4 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </button>

          <!-- Dots -->
          <div class="absolute bottom-3 left-1/2 -translate-x-1/2 z-20 flex gap-1.5 flex-wrap justify-center max-w-[80%]">
            {fotos.map((_, i) => (
              <button data-qs-dot={i} aria-label={`Foto ${i+1}`}
                class={`rounded-full transition-all ${i === 0 ? 'w-5 h-2 bg-white' : 'w-2 h-2 bg-white/40'}`} />
            ))}
          </div>
        </div>
      </div>

      <!-- Texto -->
      <div>
        <p class="reveal text-xs font-semibold tracking-widest uppercase mb-4" style="color:#127139">Nuestra empresa</p>
        <h2 class="reveal text-3xl md:text-4xl lg:text-[2.6rem] font-bold leading-tight mb-6 text-gray-900" style="transition-delay:.08s">
          Una empresa que<br/>cumple su palabra.
        </h2>
        <p class="reveal text-base text-gray-500 leading-relaxed mb-10" style="transition-delay:.14s">
          Nacimos de la pasión por el cuidado del medio ambiente y el deseo de dar un servicio de calidad.
          Llevamos más de 30 años construyendo relaciones de confianza con empresas de todos los sectores
          en la Zona Metropolitana de Guadalajara.
        </p>

        <!-- Cards Misión / Visión / Valores -->
        <div class="reveal space-y-4" style="transition-delay:.2s">
          {cards.map((c) => (
            <div class="flex items-start gap-4 p-5 rounded-xl border border-gray-100 bg-[#f9fafb] hover:border-[#b8d9c2] transition-colors">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color:#e6f4ec">
                <svg class="w-5 h-5" style="color:#127139" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" set:html={c.icono} />
              </div>
              <div>
                <p class="font-semibold text-gray-900 mb-1">{c.titulo}</p>
                <p class="text-sm text-gray-500 leading-relaxed">{c.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  (() => {
    const total = 15;
    let cur = 0, timer: ReturnType<typeof setInterval>;

    function goTo(n: number) {
      const prev = cur;
      cur = (n + total) % total;
      const slides = document.querySelectorAll<HTMLElement>('[id^="qs-slide-"]');
      const dots   = document.querySelectorAll<HTMLElement>('[data-qs-dot]');
      slides[prev].classList.replace('opacity-100','opacity-0');
      slides[prev].classList.replace('z-10','z-0');
      slides[cur].classList.replace('opacity-0','opacity-100');
      slides[cur].classList.replace('z-0','z-10');
      dots.forEach((d, i) => {
        const active = i === cur;
        d.className = `rounded-full transition-all ${active ? 'w-5 h-2 bg-white' : 'w-2 h-2 bg-white/40'}`;
      });
    }

    function resetTimer() { clearInterval(timer); timer = setInterval(() => goTo(cur + 1), 4000); }

    document.getElementById('qs-prev')?.addEventListener('click', () => { goTo(cur - 1); resetTimer(); });
    document.getElementById('qs-next')?.addEventListener('click', () => { goTo(cur + 1); resetTimer(); });
    document.querySelectorAll('[data-qs-dot]').forEach(d =>
      d.addEventListener('click', () => { goTo(Number((d as HTMLElement).dataset.qsDot)); resetTimer(); })
    );
    resetTimer();
  })();
</script>
