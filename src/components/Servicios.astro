---
const wa = 'https://wa.me/523314281747?text=Hola%2C%20tengo%20residuos%20que%20manejar%20y%20quisiera%20informaci%C3%B3n.';

const servicios = [
  {
    titulo: 'Recolección de Residuos de Manejo Especial',
    desc: 'Recolección, transporte y disposición final de residuos orgánicos, inorgánicos y sanitarios para fábricas, hospitales, centros comerciales y más.',
    icono: `<path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>`,
  },
  {
    titulo: 'Compra-Venta de Materiales Recuperables',
    desc: 'Compramos cartón, papel, plásticos, metales, cobre, aluminio y más. Tus residuos tienen valor.',
    icono: `<path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>`,
  },
  {
    titulo: 'Fabricación de Contenedores',
    desc: 'Fabricamos contenedores y remolques a la medida desde 1m³ hasta 30m³ con los mejores precios de la zona.',
    icono: `<path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>`,
  },
  {
    titulo: 'Fabricación de Sistemas Hidráulicos',
    desc: 'Sistemas Roll-Off, Volteo y Cuello de Ganso para el manejo eficiente de residuos de manejo especial.',
    icono: `<path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>`,
  },
  {
    titulo: 'Destrucciones Fiscales',
    desc: 'Destrucción de maquinaria, mobiliario y producto defectuoso. Desde una pieza hasta una bodega completa.',
    icono: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`,
  },
  {
    titulo: 'Asesoría y Tramitología Ambiental',
    desc: 'Te orientamos en la gestión correcta de tus residuos cumpliendo con toda la normativa ambiental vigente.',
    icono: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>`,
  },
];
---

<section id="servicios" class="py-24 md:py-32" style="background-color:#f5f5f5">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <div class="text-center max-w-2xl mx-auto mb-16">
      <p class="reveal text-xs font-semibold tracking-widest uppercase mb-3" style="color:#127139">Soluciones integrales</p>
      <h2 class="reveal text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 leading-tight" style="transition-delay:.08s">
        Lo que hacemos.
      </h2>
      <p class="reveal text-base text-gray-500 mt-4" style="transition-delay:.14s">
        Soluciones integrales para el manejo responsable de tus residuos.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {servicios.map((s, i) => (
        s.titulo === 'Destrucciones Fiscales' ? (
          <div class="reveal group bg-white rounded-2xl p-7 border border-gray-100 shadow-sm
            transition-all duration-300 hover:-translate-y-1 hover:border-[#127139] hover:shadow-[0_8px_30px_rgba(18,113,57,0.12)] cursor-pointer"
            style={`transition-delay:${i * 0.06}s`}
            onclick="document.getElementById('modal-destruccion').classList.remove('hidden')">
            <div class="w-12 h-12 rounded-full flex items-center justify-center mb-5 transition-colors group-hover:bg-[#127139]"
              style="background-color:#e6f4ec">
              <svg class="w-6 h-6 transition-colors group-hover:text-white" style="color:#127139"
                fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" set:html={s.icono} />
            </div>
            <h3 class="font-semibold text-gray-900 text-base mb-2 leading-snug">{s.titulo}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{s.desc}</p>
            <p class="text-xs font-semibold mt-3" style="color:#127139">Ver más →</p>
          </div>
        ) : (
          <div class="reveal group bg-white rounded-2xl p-7 border border-gray-100 shadow-sm
            transition-all duration-300 hover:-translate-y-1 hover:border-[#127139] hover:shadow-[0_8px_30px_rgba(18,113,57,0.12)]"
            style={`transition-delay:${i * 0.06}s`}>
            <div class="w-12 h-12 rounded-full flex items-center justify-center mb-5 transition-colors group-hover:bg-[#127139]"
              style="background-color:#e6f4ec">
              <svg class="w-6 h-6 transition-colors group-hover:text-white" style="color:#127139"
                fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" set:html={s.icono} />
            </div>
            <h3 class="font-semibold text-gray-900 text-base mb-2 leading-snug">{s.titulo}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{s.desc}</p>
          </div>
        )
      ))}
    </div>

    <!-- Modal Destrucción Fiscal -->
    <div id="modal-destruccion" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4"
      onclick="if(event.target===this)this.classList.add('hidden')"
      style="background-color:rgba(0,0,0,0.6)">
      <div class="bg-white rounded-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto shadow-2xl">
        <!-- Header -->
        <div class="flex items-center justify-between p-6 border-b border-gray-100">
          <h3 class="text-xl font-bold text-gray-900">Destrucción Fiscal de Documentos</h3>
          <button onclick="document.getElementById('modal-destruccion').classList.add('hidden')"
            class="w-8 h-8 rounded-full flex items-center justify-center text-gray-400 hover:bg-gray-100 transition-colors text-lg font-bold">✕</button>
        </div>
        <!-- Fotos -->
        <div class="grid grid-cols-3 gap-2 p-4">
          <img src="/fotos/IMG_1172.jpg" alt="Destrucción fiscal" class="rounded-xl w-full h-32 object-cover" />
          <img src="/fotos/IMG_1498_nueva.jpg" alt="Destrucción fiscal" class="rounded-xl w-full h-32 object-cover" />
          <img src="/fotos/IMG_2012.jpg" alt="Destrucción fiscal" class="rounded-xl w-full h-32 object-cover" />
        </div>
        <!-- Contenido -->
        <div class="px-6 pb-6 space-y-4">
          <p class="text-sm text-gray-600 leading-relaxed">Eliminamos tu documentación sensible de forma segura, certificada y con respaldo legal. Ideal para empresas que necesitan cumplir con sus obligaciones fiscales sin riesgos.</p>
          <div>
            <p class="font-semibold text-gray-900 mb-2 text-sm">¿Qué destruimos?</p>
            <p class="text-sm text-gray-600 leading-relaxed">Estados de cuenta, facturas, nóminas, contratos, expedientes y cualquier documento con información confidencial o con valor fiscal.</p>
          </div>
          <div>
            <p class="font-semibold text-gray-900 mb-2 text-sm">¿Cómo funciona?</p>
            <p class="text-sm text-gray-600 leading-relaxed">Recolectamos, destruimos y te entregamos un acta oficial con folio para tu tranquilidad ante el SAT y cualquier auditoría.</p>
          </div>
          <div class="rounded-xl p-4" style="background-color:#e6f4ec">
            <p class="font-semibold mb-3 text-sm" style="color:#127139">¿Por qué con JAAP?</p>
            <ul class="space-y-2 text-sm" style="color:#127139">
              <li>✓ Proceso 100% trazable</li>
              <li>✓ Acta de destrucción certificada</li>
              <li>✓ Cumplimiento ante SEMADET</li>
              <li>✓ Más de 30 años de experiencia</li>
            </ul>
          </div>
          <a href="https://wa.me/523314281747?text=Hola%2C%20quisiera%20información%20sobre%20destrucciones%20fiscales."
            target="_blank" rel="noopener noreferrer"
            class="block w-full text-center py-3 rounded-xl font-semibold text-sm transition-all hover:opacity-90"
            style="background-color:#127139; color:white">
            Solicitar información por WhatsApp
          </a>
        </div>
      </div>
    </div>

    <div class="reveal text-center mt-12">
      <a href={wa} target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full font-semibold text-sm text-white transition-all hover:opacity-90 hover:scale-[1.03]"
        style="background-color:#127139">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        ¿Tienes residuos? Escríbenos
      </a>
    </div>

  </div>
</section>
