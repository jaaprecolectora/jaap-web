---
const wa = 'https://wa.me/523314281747?text=Hola%2C%20quisiera%20una%20cotizaci%C3%B3n%20sin%20costo.';
---
<section id="filosofia" class="relative py-32 md:py-44 overflow-hidden">

  <!-- Foto de fondo -->
  <img
    src="/fotos/9EB2AA27-8DBE-46BB-A720-C5FC7FDF4ED3.JPG"
    alt="Operación JAAP"
    class="absolute inset-0 w-full h-full object-cover"
  />
  <!-- Overlay -->
  <div class="absolute inset-0" style="background-color:rgba(18,113,57,0.75)"></div>

  <!-- Contenido -->
  <div class="relative max-w-3xl mx-auto px-6 lg:px-10 text-center">
    <p class="reveal text-sm font-bold tracking-widest uppercase mb-6" style="color:#ffca05">Nuestra filosofía</p>

    <div class="reveal text-[7rem] font-bold leading-none -mb-6 select-none" style="color:rgba(255,202,5,0.45); transition-delay:.04s" aria-hidden="true">"</div>

    <blockquote class="reveal text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6" style="transition-delay:.1s">
      Mano dura contra la basura.
    </blockquote>

    <p class="reveal text-base md:text-lg font-medium mb-10" style="color:rgba(255,255,255,0.65); transition-delay:.16s">
      Porque cada residuo tiene una solución responsable.
    </p>

    <div class="reveal" style="transition-delay:.22s">
      <a href={wa} target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full font-semibold text-sm transition-all hover:scale-[1.04]"
        style="background-color:#ffca05; color:#127139">
        Solicita una cotización
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>

</section>
